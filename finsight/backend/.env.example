MISTRAL_API_KEY=your-mistral-key-here

# LLM & Embeddings (Mistral)
LLM_MODEL=mistral-large-latest
EMBEDDING_MODEL=mistral-embed

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=financial_docs

# RAG retrieval
CHUNK_SIZE=2000
CHUNK_OVERLAP=400
TOP_K_RETRIEVAL=10
MIN_RELEVANCE_SCORE=0.2

# Evaluation
RUN_EVALUATION=true

# Fraud scoring (leave blank to use heuristic scoring without XGBoost)
FRAUD_MODEL_PATH=
FRAUD_THRESHOLD=0.65

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
