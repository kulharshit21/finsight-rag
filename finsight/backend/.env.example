OPENAI_API_KEY=sk-...

# LLM & Embeddings
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=financial_docs

# RAG retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
MIN_RELEVANCE_SCORE=0.3

# Evaluation
RUN_EVALUATION=true

# Fraud scoring (leave blank to use heuristic scoring without XGBoost)
FRAUD_MODEL_PATH=
FRAUD_THRESHOLD=0.65

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
